      "details": {
        "abstract": "本系统作为工厂生产的核心大脑，实现了从订单下达到成品入库的全链路数字化。核心难点在于处理 MES BillStatus 的复杂状态机，以及支撑高并发的 IOT 设备报文解析。",
        "tech": [
          { "name": ".NET Core", "version": "v8.0" },
          { "name": "MQTT.net", "version": "v4.3" },
          { "name": "SQL Server", "version": "2022" }
        ],
        "metrics": [
          { "label": "TPS (Throughput)", "value": "1.2k/s", "percent": 85 },
          { "label": "Uptime", "value": "99.9%", "percent": 99 }
        ],
        "architecture_ascii": "[Device] --(MQTT)--> [Parser] --(Queue)--> [DB_Sync]\n                             |\n                             +-->(WebSocket)--> [Live_Monitor]",
        "features": [
          { "title": "多协议支持", "desc": "原生支持 OPC-UA, Modbus 及自定义 TCP 报文。" },
          { "title": "单据自动流转", "desc": "基于业务逻辑的 MES BillStatus 自动触发引擎。" }
        ]
      }
    },
