---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions';
import { useTranslations } from '../i18n/utils';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangToggle from '../components/LangToggle.astro';
import SearchModal from '../components/SearchModal.astro';
import Waifu from '../components/Waifu.astro';
import '../styles/global.css';
import '../styles/layout.css';

interface Props {
	title: string;
	lang: 'zh' | 'en';
}

const { title, lang } = Astro.props;
const t = useTranslations(lang);

const getRelativePath = (path: string) => `/${lang}${path}`;
---

<!doctype html>
<html lang={lang} data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="stylesheet" href="/live2d/waifu.css" />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
			integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFas9aVVUsq"
			crossorigin="anonymous"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<ClientRouter />
		<script is:inline>
			const applyTheme = () => {
				const theme = (() => {
					if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
						return localStorage.getItem('theme');
					}
					return 'dark';
				})();
				document.documentElement.setAttribute('data-theme', theme);
			};

			applyTheme();

			document.addEventListener('astro:before-swap', (e) => {
				const currentTheme = document.documentElement.getAttribute('data-theme');
				e.newDocument.documentElement.setAttribute('data-theme', currentTheme);
			});
		</script>
	</head>
	<body>
		<div id="global-loader" class="loader-wrapper">
			<div class="pixel-loader-container">
				<div class="pixel-spinner">
					<div class="dot"></div>
					<div class="dot"></div>
					<div class="dot"></div>
					<div class="dot"></div>
				</div>
				<div class="loading-content">
					<div class="status-line">
						<span class="prefix">></span> 
						<span class="loading-text" id="loader-text">INITIALIZING_SYSTEM</span>
						<span class="cursor">_</span>
					</div>
					<div class="progress-bar-container">
						<div class="progress-bar-fill"></div>
					</div>
				</div>
			</div>
		</div>
		<header class="main-header">
			<nav class="nav-container">
				<div class="nav-links">
					<a href={getRelativePath('/')}>{t('nav.home')}</a>
					<a href={getRelativePath('/blog')}>{t('nav.blog')}</a>
					<a href={getRelativePath('/projects')}>{t('nav.projects')}</a>
					<a href={getRelativePath('/awards')}>{t('nav.awards')}</a>
					<a href={getRelativePath('/schedule')}>{t('nav.schedule')}</a>
					<a href={getRelativePath('/boardgames')}>{t('nav.boardgames')}</a>
					<a href={getRelativePath('/bookmarks')}>{t('nav.bookmarks')}</a>
				</div>

				<div class="nav-controls">
					<div class="search-box">
						<input type="text" placeholder={t('nav.search')} disabled />
						<kbd>⌘K</kbd>
					</div>
					<LangToggle />
					<ThemeToggle />
				</div>
			</nav>
		</header>

		<main class="w-full pt-6 pb-20 px-4">
			<slot />
		</main>
		<SearchModal />
		<Waifu />
	</body>
	<script is:inline>
		document.addEventListener('astro:before-swap', (e) => {
			const waifu = document.getElementById('waifu');
			if (waifu) {
				e.newDocument.body.appendChild(waifu);
			}
		});
	</script>
	<script is:inline>
		if (sessionStorage.getItem('siteLoaded') === 'true') {
			document.getElementById('global-loader').remove();
		}
	</script>
	<script is:inline>
		const initLoader = () => {
			const loader = document.getElementById('global-loader');
			if (!loader) return;

			const messages = ["BOOTING_CORE", "SYNCING_DATA", "ESTABLISHING_LINK", "READY"];
			let msgIndex = 0;
			const textElem = document.getElementById('loader-text');
			
			const textInterval = setInterval(() => {
			if (textElem && msgIndex < messages.length) {
				textElem.innerText = messages[msgIndex];
				msgIndex++;
			}
			}, 400);

			window.addEventListener('load', () => {
			setTimeout(() => {
				clearInterval(textInterval);
				loader.style.opacity = '0';
				loader.style.transition = 'opacity 0.6s steps(6)';
				
				setTimeout(() => {
				loader.remove();
				sessionStorage.setItem('siteLoaded', 'true');
				}, 600);
			}, 1800);
			});
		};

		initLoader();

		document.addEventListener('astro:after-swap', () => {
			if (sessionStorage.getItem('siteLoaded') === 'true') {
			const loader = document.getElementById('global-loader');
			if (loader) loader.remove();
			}
		});
	</script>
</html>