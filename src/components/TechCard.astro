---
// src/components/TechCard.astro
interface Props {
  title: string;
  desc?: string;
  tag?: string;
  image?: string;
  href?: string;
}

const { title, desc, tag, image, href } = Astro.props;
---

<a href={href} class="card-link">
  <div class="tech-card">
    <div class="card-glow"></div>
    {image && <div class="card-image" style={`background-image: url(${image})`}></div>}
    <div class="card-content">
      {tag && <span class="card-tag">{tag}</span>}
      <h3>{title}</h3>
      <p>{desc}</p>
    </div>
  </div>
</a>

<style>
  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .tech-card {
    position: relative;
    background: var(--surface-color);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .tech-card:hover {
    transform: translateY(-8px) scale(1.02);
    border-color: var(--accent-color);
    box-shadow: 0 10px 30px -10px var(--accent-glow);
  }

  /* 悬浮时的背景扫光效果 */
  .card-glow {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(0, 240, 255, 0.1) 0%, transparent 80%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tech-card:hover .card-glow {
    opacity: 1;
  }

  .card-tag {
    font-size: 0.75rem;
    color: var(--accent-color);
    border: 1px solid var(--accent-color);
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  h3 { margin: 1rem 0 0.5rem; font-size: 1.25rem; }
  p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; }
</style>

<script>
  // 简单的 JS 实现卡片跟随鼠标的光晕效果
  document.querySelectorAll('.tech-card').forEach(card => {
    card.addEventListener('mousemove', (e: any) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
      (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>