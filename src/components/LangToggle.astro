---
// src/components/LangToggle.astro
const { pathname } = Astro.url;

const purePath = pathname.replace(/^\/(zh|en)/, '');

const pathForZh = purePath.replace(/-en\/?$/, '-zh');
const pathForEn = purePath.replace(/-zh\/?$/, '-en');

const targetZh = `/zh${pathForZh || '/'}`;
const targetEn = `/en${pathForEn || '/'}`;

const isEn = pathname.startsWith('/en');

const baseClass = "transition-all duration-300 hover:text-[var(--text-primary)]";
const activeClass = "text-[var(--accent-color)] font-bold drop-shadow-[0_0_8px_rgba(6,182,212,0.4)]";
---

<div class="flex items-center gap-2 mr-4 text-[var(--text-secondary)] font-mono leading-none">
  
  <a 
    href={targetZh} 
    class={`text-[12px] ${baseClass} ${!isEn ? activeClass : ""}`}
  >
    中文
  </a>
  
  <span class="text-[12px] opacity-40 font-light">/</span>
  
  <a 
    href={targetEn} 
    class={`text-[14px] tracking-wide ${baseClass} ${isEn ? activeClass : ""}`}
  >
    EN
  </a>
  
</div>