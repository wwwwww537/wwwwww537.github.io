---
// src/components/SearchModal.astro
---

<dialog id="search-dialog" class="cyber-dialog" transition:persist="jules-search-modal">
  <div class="dialog-content">
    <div id="search-root"></div>
  </div>
</dialog>

<style is:global>
  /* 你的样式保持不变 */
  .cyber-dialog {
    padding: 0;
    border: 1px solid var(--accent-color);
    border-radius: 12px;
    background: var(--surface-color);
    backdrop-filter: blur(16px);
    width: 90%;
    max-width: 600px;
    top: 10%;
    margin: 0 auto;
    box-shadow: 0 0 40px var(--accent-glow);
    color: var(--text-primary);
  }
  
  .cyber-dialog::backdrop {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
  }

  .dialog-content { padding: 2rem; position: relative; }
  
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--accent-color);
    --pagefind-ui-text: var(--text-primary);
    --pagefind-ui-background: var(--bg-color);
    --pagefind-ui-border: var(--border-color);
    --pagefind-ui-tag: rgba(0, 240, 255, 0.1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: inherit;
  }
  
  .pagefind-ui__search-input { 
    outline: none; 
    background: var(--surface-color) !important; 
    color: var(--text-primary) !important;
  }

  .pagefind-ui__search-clear {
    background-color: transparent !important;
    color: var(--text-secondary) !important;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.8rem;
    transition: all 0.3s ease;
  }
  .pagefind-ui__search-clear:hover {
    color: var(--accent-color) !important;
    background-color: var(--accent-glow) !important;
  }
</style>

<script is:inline>
  // 核心修复 2：将状态提升为 window 级别的全局锁，保证整个网站生命周期内只加载一次
  if (typeof window.julesSearchLoaded === 'undefined') {
    window.julesSearchLoaded = false;
    window.julesSearchBound = false;
  }

  document.addEventListener('astro:page-load', () => {
    // 因为使用了 persist，dialog 始终是同一个
    const dialog = document.getElementById('search-dialog');
    // 但导航栏按钮在每次切换页面后是新渲染的，所以每次都需要重新获取并绑定
    const searchTriggers = document.querySelectorAll('.search-box'); 
    
    const openSearch = () => {
      dialog.showModal();
      
      // 全局单例锁：没加载过才去请求 JS
      if (!window.julesSearchLoaded) {
        window.julesSearchLoaded = true;
        
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);
        
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
          new PagefindUI({ element: "#search-root", showSubResults: true, resetStyles: false });
          document.querySelector('.pagefind-ui__search-input')?.focus();
        };
        document.body.appendChild(script);
      } else {
        // 如果已经加载过了，直接让输入框获取焦点
        setTimeout(() => document.querySelector('.pagefind-ui__search-input')?.focus(), 100);
      }
    };

    const closeSearch = () => dialog.close();

    // 每次进入新页面，给新的导航栏按钮绑定打开事件
    searchTriggers.forEach(trigger => trigger.addEventListener('click', openSearch));

    // 核心修复 3：全局快捷键和弹窗关闭事件，只在初次访问时绑定一次，防止无限叠加
    if (!window.julesSearchBound) {
      window.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          // 必须实时获取 dialog 状态
          const d = document.getElementById('search-dialog');
          if (d) d.open ? closeSearch() : openSearch();
        }
      });

      // 点击遮罩外围关闭
      document.addEventListener('click', (e) => {
        const d = document.getElementById('search-dialog');
        if (d && d.open && e.target === d) {
          closeSearch();
        }
      });

      window.julesSearchBound = true;
    }
  });
</script>