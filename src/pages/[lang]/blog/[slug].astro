---
// src/pages/[lang]/blog/[slug].astro
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';
import Layout from '../../../layouts/Layout.astro';
import '../../../styles/blog-detail.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  return posts.map(post => ({
    params: { 
      lang: post.data.lang, 
      slug: post.id 
    },
    props: { post },
  }));
}

const { lang } = Astro.params;
const { post } = Astro.props;

const { Content } = await render(post);
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(currentLang);
---

<Layout title={`${post.data.title} - Jules Console`} lang={currentLang}>
  
  <article class="jules-container max-w-4xl mx-auto pt-6 pb-20 px-4">
    
    <div class="flex items-center gap-3 text-sm font-mono text-[var(--text-secondary)] mb-6 opacity-80">
      <span class="text-[var(--accent-color)]">root@jules</span>
      <span>:</span>
      <span>~/workspace/logs/{post.id}.md</span>
    </div>

    <header class="blog-header">
      <h1 transition:name={`title-${post.id}`}>{post.data.title}</h1>
      
      <div class="blog-meta">
        <span class="date">
          <span class="text-[var(--accent-color)] font-pixel">{t('blog.date')}:</span> 
          {post.data.pubDate.toLocaleDateString()}
        </span>
        <span class="category">
          <span class="text-[var(--accent-color)] font-pixel">{t('blog.dir')}:</span> 
          /{post.data.category}
        </span>
        <div class="blog-tags">
          {post.data.tech.map((tech: string) => <span class="blog-tag">#{tech}</span>)}
        </div>
      </div>
    </header>

    <div class="markdown-body jules-card p-6 md:p-10 border-0 md:border-3">
      <Content />
    </div>

    <div class="back-link-container">
      <a href={`/${lang}/blog`} class="jules-btn inline-block px-8 py-2">
        &lt; RUN: return_to_list()
      </a>
    </div>

  </article>
  
</Layout>