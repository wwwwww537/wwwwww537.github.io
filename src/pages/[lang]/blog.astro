---
// src/pages/[lang]/blog.astro
import { getCollection, type CollectionEntry } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import '../../styles/blog.css';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(currentLang); 

const allPosts = await getCollection('blog', (post: CollectionEntry<'blog'>) => {
  return post.data.lang === currentLang;
});
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(sortedPosts.map((post) => post.data.category))];
---

<Layout title={t('nav.blog')} lang={currentLang}>
  <div class="jules-container max-w-4xl mx-auto pt-8 pb-20 px-4">
    
    <header class="mb-12">
      <div class="flex items-center gap-3 text-sm font-mono text-[var(--text-secondary)] mb-2">
        <span class="text-[var(--accent-color)]">></span>
        <span>cat ~/workspace/logs/*.md</span>
      </div>
      <h1 class="text-4xl font-bold font-pixel text-[var(--text-primary)]">
        {t('blog.title')}
      </h1>
    </header>

    <nav class="category-bar">
      <button class="category-btn active" data-category="all">{t('common.all')}</button>
      {categories.map(cat => (
        <button class="category-btn" data-category={cat}>{cat}</button>
      ))}
    </nav>

    <div class="blog-list">
      {sortedPosts.map(post => (
        <a href={`/${lang}/blog/${post.id}`} data-category={post.data.category} class="blog-card">
          <div class="absolute -top-3 -right-3 px-2 py-1 bg-[var(--accent-color)] text-black text-[10px] font-bold font-pixel">
            LOG_ID: {post.id.slice(0, 5).toUpperCase()}
          </div>
          
          <h3>{post.data.title}</h3>
          
          <p>{post.data.desc}</p>
          
          <div class="blog-meta">
            <span class="date">
              <span class="opacity-50 tracking-normal">{t('blog.publish')}:</span> {post.data.pubDate.toLocaleDateString()}
            </span>
            <span class="category-tag">
              #{post.data.category}
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-20 py-8 border-t-2 border-dashed border-[var(--border-color)] text-center font-mono text-xs opacity-40">
      EOF (End Of File) - JulesOS v4.0.2
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll('.category-btn');
    const cards = document.querySelectorAll('.blog-card');

    if (buttons.length === 0 || cards.length === 0) return;

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const targetCategory = btn.getAttribute('data-category');

        cards.forEach(card => {
          const cardCategory = card.getAttribute('data-category');
          const cardElem = card as HTMLElement;
          
          if (targetCategory === 'all' || targetCategory === cardCategory) {
            cardElem.style.display = ''; 
          } else {
            cardElem.style.display = 'none'; 
          }
        });
      });
    });
  });
</script>