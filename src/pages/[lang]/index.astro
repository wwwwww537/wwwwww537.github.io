---
// src/pages/[lang]/index.astro
import { getCollection } from 'astro:content';
import { useTranslations } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import logsData from '../../data/logs.json';
import '../../styles/home.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(currentLang);
const getRelativePath = (path: string) => `/${currentLang}${path}`;

const logs = logsData[currentLang];
const allProjects = await getCollection('projects', ({ data }) => data.lang === currentLang);
const displayProjects = allProjects.slice(0, 3);
---

<Layout title="Wwwwww537 - Jules Console" lang={currentLang}>
  
  <div class="jules-container max-w-6xl mx-auto flex flex-col md:flex-row gap-6 items-start pt-6 pb-16 px-4">
    
    <aside class="w-full md:w-[300px] flex-shrink-0 flex flex-col gap-6 md:sticky top-20 z-10">
      
      <div class="jules-card data-stream-border p-6 flex flex-col items-center text-center">
        <div class="w-20 h-20 rounded-[1rem] border-2 border-[var(--text-primary)] dark:border-[rgba(255,255,255,0.4)] bg-[var(--accent-color)]/20 flex items-center justify-center text-3xl mb-4 relative">
          <img 
            src="/logo.png" 
            alt="Profile Avatar" 
            class="relative z-10 w-full h-full object-cover rounded-[14px]" 
          />
          <div class="absolute inset-0 border-2 border-[var(--accent-color)] rounded-[1rem] transform translate-x-1.5 translate-y-1.5 -z-10 opacity-50"></div>
        </div>
        
        <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-1">Wwwwww537</h1>
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/30 text-green-600 dark:text-green-400 text-xs mb-6 pixel-text font-bold">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> {t('home.profile.status')}
        </div>
        
        <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-6">
          {t('home.profile.title')}<br/>
          {t('home.profile.subTitle')}
        </p>

        <div class="w-full flex flex-col gap-3">
          <a href="https://github.com/wwwwww537" target="_blank" class="jules-btn w-full py-2.5">GitHub</a>
        </div>
      </div>

      <div class="jules-card data-stream-border p-4">
        <h2 class="text-xs text-[var(--text-secondary)] mb-3 px-2">/// MENU</h2>
        <nav class="flex flex-col gap-2">
          <a href={getRelativePath('/schedule')} class="jules-nav-item group">
            <span>📅 {t('nav.schedule')}</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
          <a href={getRelativePath('/boardgames')} class="jules-nav-item group">
            <span>🎲 {t('nav.boardgames')}</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
          <a href={getRelativePath('/awards')} class="jules-nav-item group">
            <span>🏆 {t('nav.awards')}</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
        </nav>
      </div>

    </aside>

    <main class="flex-1 w-full jules-card data-stream-border p-6 md:p-10 flex flex-col">
      
      <div class="flex items-center justify-between mb-8 pb-4 border-b-2 border-dashed border-[var(--border-color)]">
        <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)] pixel-text">
          <span class="text-[var(--accent-color)] text-lg">★</span> 
          <span>~/workspace/dashboard</span>
        </div>
        <div class="text-xs px-2 py-1 bg-black/5 dark:bg-white/5 rounded border border-[var(--border-color)] pixel-text">
          v4.0.2
        </div>
      </div>

      <section class="mb-10">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="text-[var(--accent-color)]">#</span> Stack
        </h3>
        <div class="flex flex-wrap gap-3">
          <span class="jules-tag">C# / .NET</span>
          <span class="jules-tag">Astro</span>
          <span class="jules-tag">React</span>
          <span class="jules-tag">Node.js</span>
          <span class="jules-tag">SQL Server</span>
        </div>
      </section>

      <section class="mb-10">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="text-[var(--accent-color)]">#</span> Systems
        </h3>
        {displayProjects.map((proj) => (
          <a href={`/${lang}/projects/${proj.id}`} class="block group">
            <div class="jules-inner-card group-hover:border-[var(--text-primary)] transition-all">
              <div class="flex justify-between items-start mb-2">
                <h4 class="text-xl font-bold group-hover:text-[var(--accent-color)] transition-colors font-pixel">
                  {proj.data.title}
                </h4>
                <span class="text-[10px] px-2 py-0.5 border-2 border-[var(--text-primary)] font-bold font-pixel">
                  {proj.data.status}
                </span>
              </div>
              <p class="text-[var(--text-secondary)] text-sm mb-4 leading-relaxed line-clamp-2">
                {proj.data.desc}
              </p>
              <div class="flex gap-4 text-[10px] text-[var(--text-secondary)] font-mono uppercase">
                <span>> ARCH: {proj.data.tech[0]}</span>
                <span class="text-[var(--accent-color)] group-hover:translate-x-1 transition-transform">
                  [ ACCESS_DATA ] ->
                </span>
              </div>
            </div>
          </a>
        ))}
      </section>

      <section>
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-bold flex items-center gap-2">
            <span class="text-[var(--accent-color)]">#</span> Logs
          </h3>
          <a href="/blog" class="text-xs hover:text-[var(--accent-color)] underline decoration-dashed transition-colors pixel-text">{t('common.viewAll')}</a>
        </div>
        
        <div class="pl-2 space-y-8">
          {logs.map((log) => (
            <div class="relative pl-8 timeline-line">
              <div class={`absolute left-0 top-1.5 pixel-dot border-2 bg-[var(--surface-color)] ${log.type === 'primary' ? 'border-[var(--accent-color)]' : 'border-[var(--text-primary)]'}`}></div>
              <div class="text-xs text-[var(--accent-color)] mb-1 pixel-text">{log.date}</div>
              <h4 class="font-bold">{log.title}</h4>
              <p class="text-sm text-[var(--text-secondary)] mt-1">{log.desc}</p>
            </div>
          ))}
        </div>
      </section>

    </main>

  </div>
</Layout>