---
// src/pages/[lang]/index.astro
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
---

<Layout title="Wwwwww537 - Jules Console" lang={lang as 'zh' | 'en'}>
  
  <div class="jules-container max-w-6xl mx-auto flex flex-col md:flex-row gap-6 items-start pt-6 pb-16 px-4">
    
    <aside class="w-full md:w-[300px] flex-shrink-0 flex flex-col gap-6 md:sticky top-20 z-10">
      
      <div class="jules-card p-6 flex flex-col items-center text-center">
        <div class="w-20 h-20 rounded-[1rem] border-2 border-[var(--text-primary)] dark:border-[rgba(255,255,255,0.4)] bg-[var(--accent-color)]/20 flex items-center justify-center text-3xl mb-4 relative">
          <span class="relative z-10 pixel-text">👾</span>
          <div class="absolute inset-0 border-2 border-[var(--accent-color)] rounded-[1rem] transform translate-x-1.5 translate-y-1.5 -z-10 opacity-50"></div>
        </div>
        
        <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-1">Wwwwww537</h1>
        <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/30 text-green-600 dark:text-green-400 text-xs mb-6 pixel-text font-bold">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span> ONLINE
        </div>
        
        <p class="text-[var(--text-secondary)] text-sm leading-relaxed mb-6">
          Software Engineer.<br/>
          Building MES & Astro.
        </p>

        <div class="w-full flex flex-col gap-3">
          <a href="https://github.com/wwwwww537" target="_blank" class="jules-btn w-full py-2.5">GitHub</a>
        </div>
      </div>

      <div class="jules-card p-4">
        <h2 class="text-xs text-[var(--text-secondary)] mb-3 px-2">/// MENU</h2>
        <nav class="flex flex-col gap-2">
          <a href="/schedule" class="jules-nav-item group">
            <span>📅 Schedule</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
          <a href="/boardgames" class="jules-nav-item group">
            <span>🎲 Boardgames</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
          <a href="/awards" class="jules-nav-item group">
            <span>🏆 Awards</span> <span class="opacity-0 group-hover:opacity-100 transition-opacity">-></span>
          </a>
        </nav>
      </div>

    </aside>

    <main class="flex-1 w-full jules-card p-6 md:p-10 flex flex-col">
      
      <div class="flex items-center justify-between mb-8 pb-4 border-b-2 border-dashed border-[var(--border-color)]">
        <div class="flex items-center gap-3 text-sm text-[var(--text-secondary)] pixel-text">
          <span class="text-[var(--accent-color)] text-lg">★</span> 
          <span>~/workspace/dashboard</span>
        </div>
        <div class="text-xs px-2 py-1 bg-black/5 dark:bg-white/5 rounded border border-[var(--border-color)] pixel-text">
          v4.0.2
        </div>
      </div>

      <section class="mb-10">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="text-[var(--accent-color)]">#</span> Stack
        </h3>
        <div class="flex flex-wrap gap-3">
          <span class="jules-tag">C# / .NET</span>
          <span class="jules-tag">Astro</span>
          <span class="jules-tag">React</span>
          <span class="jules-tag">Node.js</span>
          <span class="jules-tag">SQL Server</span>
        </div>
      </section>

      <section class="mb-10">
        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
          <span class="text-[var(--accent-color)]">#</span> Systems
        </h3>
        
        <div class="jules-inner-card group">
          <div class="flex justify-between items-start mb-2">
            <h4 class="text-xl font-bold group-hover:text-[var(--accent-color)] transition-colors">MES (制造执行系统)</h4>
            <span class="text-xs px-2 py-1 rounded border border-[var(--text-primary)] dark:border-[rgba(255,255,255,0.4)] pixel-text font-bold">ACTIVE</span>
          </div>
          <p class="text-[var(--text-secondary)] text-sm mb-4 leading-relaxed">
            工业级数据管理平台。负责处理复杂的工艺单据状态流转，高并发设备报文解析与系统对接。
          </p>
          <div class="flex gap-4 text-xs text-[var(--text-secondary)] pixel-text">
            <span>> Arch: .NET Core</span>
            <span>> DB: SQL Views</span>
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-bold flex items-center gap-2">
            <span class="text-[var(--accent-color)]">#</span> Logs
          </h3>
          <a href="/blog" class="text-xs hover:text-[var(--accent-color)] underline decoration-dashed transition-colors pixel-text">View All</a>
        </div>
        
        <div class="pl-2 space-y-8">
          
          <div class="relative pl-6 jules-log-item">
            <div class="absolute left-0 top-1.5 w-2 h-2 rounded-full border-2 border-[var(--accent-color)] bg-[var(--surface-color)] jules-dot"></div>
            <div class="text-xs text-[var(--accent-color)] mb-1 pixel-text">2026.04.20</div>
            <h4 class="font-bold">Astro 控制台重构 (Jules Style)</h4>
            <p class="text-sm text-[var(--text-secondary)] mt-1">引入 DotGothic16 字体，切换至极客像素风，优化左右视窗排版。</p>
          </div>

          <div class="relative pl-6 jules-log-item">
            <div class="absolute left-0 top-1.5 w-2 h-2 rounded-full border-2 border-[var(--text-primary)] dark:border-white/50 bg-[var(--surface-color)] jules-dot"></div>
            <div class="text-xs text-[var(--text-secondary)] mb-1 pixel-text">2026.04.18</div>
            <h4 class="font-bold">上周末桌游局账单已上传</h4>
            <p class="text-sm text-[var(--text-secondary)] mt-1">本次阿瓦隆面杀费用明细及发票记录已归档，请前往私密模块对账。</p>
          </div>

          <div class="relative pl-6 jules-log-item">
            <div class="absolute left-0 top-1.5 w-2 h-2 rounded-full border-2 border-[var(--text-primary)] dark:border-white/50 bg-[var(--surface-color)] jules-dot"></div>
            <div class="text-xs text-[var(--text-secondary)] mb-1 pixel-text">2026.04.10</div>
            <h4 class="font-bold">Node.js 部署冲突排雷</h4>
            <p class="text-sm text-[var(--text-secondary)] mt-1">记录 GitHub Actions 中 Node v20/v22 的冲突解决过程。</p>
          </div>

        </div>
      </section>

    </main>

  </div>
</Layout>