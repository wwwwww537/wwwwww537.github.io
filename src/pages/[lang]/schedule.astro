---
// src/pages/[lang]/schedule.astro 核心修改
import Layout from '../../layouts/Layout.astro';
import scheduleData from '../../data/schedule.json';
import logsData from '../../data/logs.json'; // 引入日志数据
import InteractiveCalendar from '../../components/InteractiveCalendar.jsx'; // 新建 React 组件
import '../../styles/schedule.css';

export function getStaticPaths() {
    return [
        { params: { lang: 'zh' } },
        { params: { lang: 'en' } }
    ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const data = scheduleData[currentLang];
const logs = logsData[currentLang]; // 获取日志
---

<Layout title={currentLang === 'zh' ? '行程调度中心' : 'TASK_SCHEDULER'} lang={currentLang}>
  <div class="jules-container max-w-7xl mx-auto pt-6 pb-20 px-4">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <main class="lg:col-span-3">
        <InteractiveCalendar client:load lang={currentLang} events={data.events} monthName={data.current_month} />
      </main>

      <aside class="flex flex-col gap-6">
        <div class="task-list-card jules-card p-4">
          <h3 class="font-pixel text-sm border-b-2 border-[var(--text-primary)] pb-2 mb-4">SYSTEM_LOGS</h3>
          <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2">
            {logs.map(log => (
              <div class="relative pl-6 border-l-2 border-dashed border-[var(--border-color)] pb-2">
                <div class={`absolute -left-[5px] top-1 w-2 h-2 rotate-45 border-2 bg-[var(--surface-color)] ${log.type === 'primary' ? 'border-[var(--accent-color)]' : 'border-[var(--text-primary)]'}`}></div>
                <div class="text-[10px] font-mono opacity-50">{log.date}</div>
                <div class="font-bold text-xs font-pixel">{log.title}</div>
                <div class="text-[10px] text-[var(--text-secondary)]">{log.desc}</div>
              </div>
            ))}
          </div>
        </div>
        </aside>
    </div>
  </div>
</Layout>