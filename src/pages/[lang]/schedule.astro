---
// src/pages/[lang]/schedule.astro
import { useTranslations } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import scheduleData from '../../data/schedule.json';
import InteractiveCalendar from '../../components/InteractiveCalendar.jsx';
import '../../styles/schedule.css';

export function getStaticPaths() {
    return [
        { params: { lang: 'zh' } },
        { params: { lang: 'en' } }
    ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(currentLang); 
const data = scheduleData[currentLang];
const logs = data.events; 
---

<Layout title={t('nav.schedule')} lang={currentLang}>
  <div class="jules-container max-w-7xl mx-auto pt-6 pb-20 px-4">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <main class="lg:col-span-3">
        <InteractiveCalendar key={currentLang} client:load lang={currentLang} events={data.events}/>
      </main>

      <aside class="lg:col-span-1 relative mt-8 lg:mt-0">
        <div class="lg:absolute lg:inset-0 h-[500px] lg:h-full flex flex-col">
          <div class="task-list-card jules-card p-5 flex flex-col h-full min-h-0">
            <h3 class="font-pixel text-base border-b-2 border-[var(--text-primary)] pb-3 mb-5 flex-shrink-0">
              SYSTEM_LOGS
            </h3>
            
            <div class="space-y-6 overflow-y-auto pr-4 custom-scrollbar flex-1 min-h-0">
              {logs.slice().reverse().map(log => (
                <div class="log-item relative pl-6 border-l-2 border-dashed border-[var(--border-color)] pb-2 cursor-pointer hover:bg-[var(--border-color)] transition-colors rounded-r-lg pt-1 pr-2 group" data-date={log.date}>
                  <div class={`absolute -left-[6px] top-2 w-2.5 h-2.5 rotate-45 border-2 bg-[var(--surface-color)] ${log.type === 'work' ? 'border-[var(--accent-color)]' : 'border-[var(--text-primary)]'}`}></div>
                  
                  <div class="text-xs font-mono opacity-60 mb-1.5 group-hover:opacity-100 transition-opacity">
                    {log.date} {log.time && `<${log.time}>`}
                  </div>
                  
                  <div class="font-bold text-sm font-pixel leading-snug mb-1.5">
                    {log.title}
                  </div>
                  
                  <div class="text-xs text-[var(--text-secondary)] leading-relaxed">
                    {log.desc}
                  </div>

                  {log.link && log.link.url && (
                    <div class="mt-3 mb-1">
                      <a href={log.link.url} target={log.link.type === 'external' ? "_blank" : "_self"} rel="noopener noreferrer" class="inline-block text-xs font-mono px-2 py-1 border border-[var(--text-primary)] text-[var(--text-primary)] hover:bg-[var(--text-primary)] hover:text-[var(--bg-color)] transition-colors" onclick="event.stopPropagation();">
                        [{log.link.label || t('common.link')}]
                      </a>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    
    const logItem = target.closest('.log-item');
    
    if (logItem) {
      const date = logItem.getAttribute('data-date');
      if (date) {
        const jumpEvent = new CustomEvent('calendar-jump', { detail: { date } });
        window.dispatchEvent(jumpEvent);
      }
    }
  });
</script>