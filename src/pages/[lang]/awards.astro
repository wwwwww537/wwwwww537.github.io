---
// src/pages/[lang]/awards.astro
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';
import '../../styles/awards.css'; // 引入专属像素样式
import awardsData from '../../data/awards.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(lang as 'zh' | 'en');

const awards = awardsData[currentLang];
---

<Layout title={`${t('nav.awards')} - Jules Console`} lang={lang as 'zh' | 'en'}>
  <div class="jules-container max-w-5xl mx-auto pt-8 pb-20 px-4">
    
    <header class="mb-14 border-b-4 border-dashed border-[var(--border-color)] pb-8">
      <div class="flex items-center gap-3 text-sm font-mono text-[var(--text-secondary)] mb-3 opacity-80">
        <span class="text-[var(--accent-color)]">></span>
        <span>ls ~/workspace/achievements/ --all</span>
      </div>
      <h1 transition:name="hero-title" class="text-4xl font-bold font-pixel text-[var(--text-primary)] mb-4">
        {t('nav.awards')}
      </h1>
      <p class="font-mono text-[var(--text-secondary)] leading-relaxed max-w-2xl">
        {t('awards.desc')}
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-2xl font-bold font-pixel mb-8 flex items-center gap-3 text-[var(--text-primary)]">
        <span class="w-3 h-3 bg-[var(--accent-color)] inline-block"></span>
        {t('awards.patents')}
      </h2>
      
      <div class="awards-grid">
        {awards.patents.map((item: any) => (
          <a href={item.link || '#'} target={item.link ? "_blank" : "_self"} class="award-card group">
            <div class="award-tag">{item.tag}</div>
            <div class="award-icon font-pixel">📝</div>
            <h3 class="font-pixel text-xl mb-3 text-[var(--text-primary)] group-hover:text-[var(--accent-color)] transition-colors leading-tight">
              {item.title}
            </h3>
            <p class="font-mono text-sm text-[var(--text-secondary)] flex-grow leading-relaxed">
              {item.desc}
            </p>
            <div class="mt-4 pt-3 border-t-2 border-dashed border-[var(--border-color)] font-mono text-xs opacity-50 group-hover:opacity-100 transition-opacity">
              [ VERIFY_RECORD ] ->
            </div>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold font-pixel mb-8 flex items-center gap-3 text-[var(--text-primary)]">
        <span class="w-3 h-3 bg-[var(--text-primary)] inline-block"></span>
        {t('awards.certs')}
      </h2>
      
      <div class="awards-grid">
        {awards.certificates.map((item: any) => (
          <a href={item.link || '#'} target={item.link ? "_blank" : "_self"} class="award-card group">
            <div class="award-tag">{item.tag}</div>
            <div class="award-icon font-pixel">🎓</div>
            <h3 class="font-pixel text-xl mb-3 text-[var(--text-primary)] group-hover:text-[var(--accent-color)] transition-colors leading-tight">
              {item.title}
            </h3>
            <p class="font-mono text-sm text-[var(--text-secondary)] flex-grow leading-relaxed">
              {item.desc}
            </p>
            <div class="mt-4 pt-3 border-t-2 border-dashed border-[var(--border-color)] font-mono text-xs opacity-50 group-hover:opacity-100 transition-opacity">
              [ VERIFY_RECORD ] ->
            </div>
          </a>
        ))}
      </div>
    </section>

    <div class="mt-16 text-center font-pixel text-xs text-[var(--text-secondary)] opacity-50">
      *** END OF ACHIEVEMENTS BUFFER ***
    </div>

  </div>
</Layout>