---
// src/pages/[lang]/awards.astro
import { useTranslations } from '../../i18n/utils';
import Layout from '../../layouts/Layout.astro';
import awardsData from '../../data/awards.json';
import '../../styles/awards.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'zh') as 'zh' | 'en';
const t = useTranslations(currentLang);

const awards = awardsData[currentLang];
---

<Layout title={`${t('nav.awards')} - Jules Console`} lang={currentLang}>
  <div class="jules-container max-w-5xl mx-auto pt-8 pb-20 px-4">
    
    <header class="mb-14 border-b-4 border-dashed border-[var(--border-color)] pb-8">
      <div class="flex items-center gap-3 text-sm font-mono text-[var(--text-secondary)] mb-3 opacity-80">
        <span class="text-[var(--accent-color)]">></span>
        <span>ls ~/workspace/achievements/ --all</span>
      </div>
      <h1 transition:name="hero-title" class="text-4xl font-bold font-pixel text-[var(--text-primary)] mb-4">
        {t('nav.awards')}
      </h1>
      <p class="font-mono text-[var(--text-secondary)] leading-relaxed max-w-2xl">
        {t('awards.desc')}
      </p>
    </header>

    <section class="mb-16">
      <h2 class="text-2xl font-bold font-pixel mb-8 flex items-center gap-3 text-[var(--text-primary)]">
        <span class="w-3 h-3 bg-[var(--accent-color)] inline-block animate-pulse"></span>
        {t('awards.patents')}
      </h2>
      
      <div class="awards-grid">
        {awards.patents.map((item: any) => (
          <div class="award-card data-stream-border group cursor-pointer" data-img={item.image} data-title={item.title}>
            <div class="award-tag">{item.tag}</div>
            
            {item.image ? (
              <div class="w-full aspect-[3/4] mb-5 border-2 border-[var(--border-color)] relative overflow-hidden bg-[#050505] flex items-center justify-center p-3">
                <div class="absolute inset-0 bg-[var(--accent-color)] mix-blend-overlay opacity-30 group-hover:opacity-0 transition-opacity z-20 duration-500 pointer-events-none"></div>
                <div class="absolute inset-0 pointer-events-none z-10 opacity-20" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--accent-color) 3px, transparent 3px); background-size: 100% 4px;"></div>
                <img 
                    src={item.image} 
                    alt={item.title} 
                    class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-500 scale-95 group-hover:scale-100 opacity-80 group-hover:opacity-100 relative z-0 drop-shadow-[0_0_10px_rgba(255,255,255,0.1)]" 
                />
              </div>
            ) : (
              <div class="award-icon font-pixel">📝</div>
            )}
            
            <h3 class="font-pixel text-xl mb-3 text-[var(--text-primary)] group-hover:text-[var(--accent-color)] transition-colors leading-tight">
              {item.title}
            </h3>
            <p class="font-mono text-sm text-[var(--text-secondary)] flex-grow leading-relaxed">
              {item.desc}
            </p>
            <div class="mt-4 pt-3 border-t-2 border-dashed border-[var(--border-color)] font-mono text-xs text-[var(--accent-color)] opacity-50 group-hover:opacity-100 transition-opacity flex justify-between">
              <span>[ VERIFY_RECORD ]</span>
              <span>{item.image ? '🔍 VIEW' : '->'}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold font-pixel mb-8 flex items-center gap-3 text-[var(--text-primary)]">
        <span class="w-3 h-3 bg-[var(--text-primary)] inline-block"></span>
        {t('awards.certs')}
      </h2>
      
      <div class="awards-grid">
        {awards.certificates.map((item: any) => (
          <div class="award-card data-stream-border group cursor-pointer" data-img={item.image} data-title={item.title}>
            <div class="award-tag">{item.tag}</div>
            
            {item.image ? (
              <div class="w-full aspect-[3/4] mb-5 border-2 border-[var(--border-color)] relative overflow-hidden bg-[#050505] flex items-center justify-center p-3">
                <div class="absolute inset-0 bg-[var(--accent-color)] mix-blend-overlay opacity-30 group-hover:opacity-0 transition-opacity z-20 duration-500 pointer-events-none"></div>
                <div class="absolute inset-0 pointer-events-none z-10 opacity-20" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, var(--accent-color) 3px, transparent 3px); background-size: 100% 4px;"></div>
                <img 
                    src={item.image} 
                    alt={item.title} 
                    class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-500 scale-95 group-hover:scale-100 opacity-80 group-hover:opacity-100 relative z-0 drop-shadow-[0_0_10px_rgba(255,255,255,0.1)]" 
                />
              </div>
            ) : (
              <div class="award-icon font-pixel">🎓</div>
            )}
            
            <h3 class="font-pixel text-xl mb-3 text-[var(--text-primary)] group-hover:text-[var(--accent-color)] transition-colors leading-tight">
              {item.title}
            </h3>
            <p class="font-mono text-sm text-[var(--text-secondary)] flex-grow leading-relaxed">
              {item.desc}
            </p>
            <div class="mt-4 pt-3 border-t-2 border-dashed border-[var(--border-color)] font-mono text-xs opacity-50 group-hover:opacity-100 transition-opacity flex justify-between">
              <span>[ VERIFY_RECORD ]</span>
              <span>{item.image ? '🔍 VIEW' : '->'}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="mt-16 text-center font-pixel text-xs text-[var(--text-secondary)] opacity-50">
      *** END OF ACHIEVEMENTS BUFFER ***
    </div>

  </div>

  <dialog id="image-modal" class="jules-card p-0 backdrop:bg-black/90 bg-[var(--bg-color)] border-2 border-[var(--accent-color)] w-11/12 max-w-5xl m-auto fixed inset-0 z-50 shadow-[0_0_30px_rgba(6,182,212,0.3)]">
    <div class="flex justify-between items-center p-3 border-b-2 border-dashed border-[var(--border-color)] bg-[var(--surface-color)]">
        <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-[var(--accent-color)] animate-pulse"></span>
            <h3 id="modal-title" class="font-pixel text-[var(--accent-color)] text-sm tracking-widest">IMAGE_VIEWER</h3>
        </div>
        <button id="close-modal" class="jules-btn px-3 py-1 font-pixel text-xs hover:bg-red-600 hover:text-white hover:border-red-600 transition-colors">[ X ] {t('common.close')}</button>
    </div>
    <div class="p-4 flex justify-center items-center bg-[var(--bg-color)] min-h-[50vh] relative">
        <div class="absolute inset-0 pointer-events-none opacity-20" style="background-image: linear-gradient(var(--border-color) 1px, transparent 1px), linear-gradient(90deg, var(--border-color) 1px, transparent 1px); background-size: 20px 20px;"></div>
        <img id="modal-image" src="" alt="Full view" class="max-w-full max-h-[75vh] object-contain relative z-10 border-2 border-[var(--text-primary)]" />
    </div>
  </dialog>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const modal = document.getElementById('image-modal') as HTMLDialogElement;
    const modalImg = document.getElementById('modal-image') as HTMLImageElement;
    const modalTitle = document.getElementById('modal-title');
    const closeBtn = document.getElementById('close-modal');
    const cards = document.querySelectorAll('.award-card');

    if(!modal) return;

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const imgSrc = card.getAttribute('data-img');
        const title = card.getAttribute('data-title');
        
        if (imgSrc) {
          modalImg.src = imgSrc;
          if(modalTitle) modalTitle.innerText = title || 'DOCUMENT_VIEWER';
          modal.showModal();
        } else {
          // const link = card.getAttribute('data-link');
          // if(link) window.open(link, '_blank');
        }
      });
    });

    closeBtn?.addEventListener('click', () => {
      modal.close();
      modalImg.src = '';
    });

    modal.addEventListener('click', (e) => {
      const dialogDimensions = modal.getBoundingClientRect()
      if (
        e.clientX < dialogDimensions.left ||
        e.clientX > dialogDimensions.right ||
        e.clientY < dialogDimensions.top ||
        e.clientY > dialogDimensions.bottom
      ) {
        modal.close();
        modalImg.src = '';
      }
    });
  });
</script>